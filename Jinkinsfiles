pipeline {
    agent any

    stages {

        stage('Clone Code') {
            steps {
                git 'https://github.com/suamn89/zomato_clone.git'
            }
        }

        stage('Verify Docker') {
            steps {
                sh 'docker ps'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t zomato-clone .'
            }
        }

        stage('Scan Image with Trivy') {
            steps {
                sh '''
                trivy image zomato-clone > trivy-report.txt
                '''
            }
        }

        stage('Stop Old Container') {
            steps {
                sh 'docker rm -f zomato-container || true'
            }
        }

        stage('Run Container') {
            steps {
                sh 'docker run -d -p 5173:5173 --name zomato-container zomato-clone'
            }
        }
    }
}
