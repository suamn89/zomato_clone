pipeline {
    agent any

    environment {
        IMAGE_NAME = "zomato-clone"
        CONTAINER_NAME = "zomato-container"
    }

    stages {

        stage('Clone Code') {
            steps {
                git 'https://github.com/suamn89/zomato_clone.git'
            }
        }

        stage('Verify Docker') {
            steps {
                sh 'docker ps'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t $IMAGE_NAME .'
            }
        }

       stage('Trivy Scan') {
    steps {
        sh '''
        docker run --rm \
        -v /var/run/docker.sock:/var/run/docker.sock \
        -v $(pwd):/root/.cache/ \
        aquasec/trivy:latest image \
        --no-progress \
        --format table \
        zomato-clone > trivy-report.txt
        '''
    }
}

        stage('Stop Old Container') {
            steps {
                sh 'docker rm -f $CONTAINER_NAME || true'
            }
        }

        stage('Run Container') {
            steps {
                sh 'docker run -d -p 5173:5173 --name $CONTAINER_NAME $IMAGE_NAME'
            }
        }

        stage('Archive Trivy Report') {
            steps {
                archiveArtifacts artifacts: 'trivy-report.txt', fingerprint: true
            }
        }
    }

    post {
        success {
            echo '✅ Deployment Successful with Security Scan!'
        }
        failure {
            echo '❌ Build Failed due to vulnerabilities or errors!'
        }
    }
}
