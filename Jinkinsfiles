pipeline {
    agent any

    environment {
        IMAGE_NAME = "zomato-clone"
        CONTAINER_NAME = "zomato-container"
        PORT = "5173"
    }

    stages {

        stage('Clean Workspace') {
            steps {
                deleteDir()
            }
        }

        stage('Clone Code') {
            steps {
                git branch: 'master', url: 'https://github.com/suamn89/zomato_clone.git'
            }
        }

        stage('Verify Docker') {
            steps {
                sh 'docker ps'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t $IMAGE_NAME .'
            }
        }

        stage('Stop Old Container') {
            steps {
                sh 'docker rm -f $CONTAINER_NAME || true'
            }
        }

        stage('Run Container') {
            steps {
                sh '''
                docker run -d \
                -p $PORT:$PORT \
                --name $CONTAINER_NAME \
                $IMAGE_NAME
                '''
            }
        }

        stage('Check Running Container') {
            steps {
                sh 'docker ps'
            }
        }
    }

    post {
        success {
            echo '✅ Deployment Successful! Access your app at http://localhost:5173'
        }
        failure {
            echo '❌ Pipeline Failed! Check logs'
        }
    }
}
